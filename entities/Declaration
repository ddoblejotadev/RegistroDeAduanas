{
  "name": "Declaration",
  "type": "object",
  "properties": {
    "nombre_completo": {
      "type": "string",
      "description": "Nombre completo del viajero"
    },
    "rut": {
      "type": "string",
      "description": "RUT o número de documento del viajero"
    },
    "tipo_documento": {
      "type": "string",
      "enum": [
        "RUT",
        "Pasaporte",
        "Cédula de Identidad",
        "Otro"
      ],
      "description": "Tipo de documento de identidad"
    },
    "nacionalidad": {
      "type": "string",
      "description": "Nacionalidad del viajero"
    },
    "fecha_nacimiento": {
      "type": "string",
      "format": "date",
      "description": "Fecha de nacimiento del viajero"
    },
    "paso_fronterizo": {
      "type": "string",
      "description": "Paso fronterizo terrestre — ej. Paso Los Libertadores"
    },
    "pais_destino": {
      "type": "string",
      "description": "País de destino del viajero"
    },
    "tipo_viaje": {
      "type": "string",
      "enum": [
        "ingreso",
        "salida"
      ],
      "description": "Tipo de viaje: ingreso o salida del país"
    },
    "vehiculo": {
      "type": "object",
      "description": "Información del vehículo (opcional)",
      "properties": {
        "patente": {
          "type": "string"
        },
        "tipo_permiso": {
          "type": "string"
        },
        "plazo_dias": {
          "type": "number"
        },
        "pais_origen": {
          "type": "string"
        }
      }
    },
    "alimentos_o_mascotas": {
      "type": "boolean",
      "default": false,
      "description": "Indica si el viajero transporta alimentos o mascotas"
    },
    "derivado_a": {
      "type": "string",
      "enum": [
        null,
        "SAG",
        "PDI"
      ],
      "default": null,
      "description": "Entidad a la que fue derivada la declaración"
    },
    "menores_a_cargo": {
      "type": "array",
      "description": "Menores de edad que viajan con el titular",
      "items": {
        "type": "object",
        "properties": {
          "nombre_completo": {
            "type": "string"
          },
          "documento": {
            "type": "string"
          },
          "tipo_documento": {
            "type": "string"
          },
          "fecha_nacimiento": {
            "type": "string",
            "format": "date"
          },
          "parentesco": {
            "type": "string"
          },
          "autorizacion_notarial": {
            "type": "boolean",
            "description": "Indica si se presentó autorización notarial para el menor"
          }
        }
      }
    },
    "documentos_presentados": {
      "type": "array",
      "description": "Documentos que el viajero indica que presentará",
      "items": {
        "type": "string",
        "enum": [
          "Cédula de Identidad",
          "Permiso de Circulación",
          "Seguro del Automóvil",
          "Certificado de Vacunación",
          "Permiso de Menor",
          "Declaración Jurada de Alimentos",
          "Documentación del Vehículo",
          "Pasaporte"
        ]
      }
    },
    "bienes": {
      "type": "array",
      "description": "Lista de bienes declarados",
      "items": {
        "type": "object",
        "properties": {
          "tipo": {
            "type": "string"
          },
          "descripcion": {
            "type": "string"
          },
          "cantidad": {
            "type": "number"
          },
          "valor_estimado": {
            "type": "number"
          },
          "requiere_sag": {
            "type": "boolean",
            "description": "Indica si el bien requiere revisión del SAG"
          }
        }
      }
    },
    "valor_total": {
      "type": "number",
      "description": "Valor total declarado en USD"
    },
    "estado": {
      "type": "string",
      "enum": [
        "pendiente",
        "en_revision",
        "derivado_sag",
        "derivado_pdi",
        "aprobado",
        "rechazado"
      ],
      "default": "pendiente",
      "description": "Estado de la declaración"
    },
    "codigo_qr": {
      "type": "string",
      "description": "Código identificador para el QR"
    },
    "notas_funcionario": {
      "type": "string",
      "description": "Notas del funcionario aduanero"
    }
  },
  "required": [
    "nombre_completo",
    "rut",
    "nacionalidad",
    "paso_fronterizo",
    "pais_destino",
    "tipo_viaje"
  ]
}
